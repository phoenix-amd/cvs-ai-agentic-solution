{
  "_comment": "Safety baseline for driving CVS. Read-only commands are auto-allowed; anything that touches the cluster (run/exec/ssh) requires human approval; catastrophic local commands are denied. The real controls are least-privilege SSH user + scoped sudo + these ask rules.",
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -fr /)",
      "Bash(rm -rf --no-preserve-root*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(dd if=*)",
      "Bash(reboot)",
      "Bash(shutdown*)",
      "Bash(halt)",
      "Bash(poweroff)",
      "Bash(init 0)",
      "Bash(init 6)",
      "Bash(systemctl reboot)",
      "Bash(systemctl poweroff)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ],
    "ask": [
      "Bash(cvs run *)",
      "Bash(cvs exec *)",
      "Bash(pytest*tests*)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(docker *)",
      "Bash(sudo *)",
      "Bash(pip uninstall*)",
      "Bash(cvs monitor *)",
      "Bash(cvs scp *)"
    ],
    "allow": [
      "Bash(cvs list*)",
      "Bash(cvs --version*)",
      "Bash(cvs copy-config*)",
      "Bash(cvs generate*)",
      "Bash(pip install*)",
      "Bash(pip list*)",
      "Bash(pip index*)",
      "Bash(pip show*)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(python3 *)",
      "Bash(ruff *)",
      "Bash(git *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/safety-guard.sh"
          }
        ]
      }
    ]
  }
}
