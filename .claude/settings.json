{
  "permissions": {
    "allow": [
      "Bash(cvs list*)",
      "Bash(cvs copy-config*)",
      "Bash(cvs --version)",
      "Bash(cvs generate*)",
      "Bash(cat *.json)",
      "Bash(cat *.log)",
      "Bash(cat *.html)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(python3 *)",
      "Bash(pip install*)",
      "Bash(pip list*)",
      "Bash(ruff *)",
      "Bash(pytest *)",
      "Bash(git *)"
    ],
    "ask": [
      "Bash(cvs run *)",
      "Bash(cvs exec *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(docker *)",
      "Bash(cvs monitor *)",
      "Bash(cvs scp *)",
      "Bash(sudo *)",
      "Bash(pip uninstall*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(dd if=*)",
      "Bash(reboot)",
      "Bash(shutdown*)",
      "Bash(halt)",
      "Bash(poweroff)",
      "Bash(init 0)",
      "Bash(init 6)",
      "Bash(systemctl reboot)",
      "Bash(systemctl poweroff)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(chmod -R 777 /)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit.sh \"$FILEPATH\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/safety-guard.sh \"$INPUT\""
          }
        ]
      }
    ]
  }
}
